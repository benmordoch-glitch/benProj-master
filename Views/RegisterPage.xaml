<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="benProj.Views.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="RegisterPage">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource BenPrimary}" Offset="0.1" />
                <GradientStop Color="White" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,20">
            <Label Text="ליצור חשבון חדש" FontSize="28" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
            <Label Text="הצטרפו לקהילת הרצים שלנו" FontSize="16" TextColor="White" Opacity="0.8" HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="1" CornerRadius="20" HasShadow="True" Padding="20" BackgroundColor="White" Margin="0,10">
            <ScrollView>
                <VerticalStackLayout Spacing="15">

                    <Entry Placeholder="שם פרטי" Text="{Binding privateName}" HorizontalTextAlignment="End" />
                    <Label Text="שם קצר מדי" IsVisible="False" TextColor="Red" FontSize="12" HorizontalTextAlignment="End" />

                    <Entry Placeholder="שם משפחה" Text="{Binding familyName}" HorizontalTextAlignment="End" />

                    <Entry Placeholder="אימייל" Keyboard="Email" Text="{Binding UserName}" HorizontalTextAlignment="End" />

                    <Label Text="תאריך לידה" HorizontalTextAlignment="End" Margin="0,5,0,0" />
                    <DatePicker Date="{Binding BirthDate}" Format="dd/MM/yyyy" />

                    <Entry Placeholder="סיסמה" IsPassword="True" HorizontalTextAlignment="End" />
                    <Entry Placeholder="אימות סיסמה" IsPassword="True" HorizontalTextAlignment="End" />

                </VerticalStackLayout>
            </ScrollView>
        </Frame>

        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,10">
            <Button Text="הרשמה" 
                BackgroundColor="{StaticResource BenPrimary}" 
                TextColor="White" 
                CornerRadius="25" 
                HeightRequest="50" 
                FontAttributes="Bold" />

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="כניסה" TextColor="{StaticResource BenPrimary}" FontAttributes="Bold" />
                <Label Text="כבר יש לך חשבון?" />
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </Grid>
    <!--<Grid
        Padding="20,0,20,0"
        ColumnSpacing="10"
        RowDefinitions="auto,*,auto"
        RowSpacing="10">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="{StaticResource BenPrimary}" />
                <GradientStop Offset="0.5" Color="White" />
            </LinearGradientBrush>
        </Grid.Background>

        --><!--  HEADER  --><!--
        <Label
            Grid.Row="0"
            Grid.Column="0"
            HorizontalOptions="Center"
            Text="ברוכים הבאים לריצה לצד המסלול"
            TextColor="White"
            VerticalOptions="Center" />
        --><!--  CONTENT  --><!--
        <Frame Grid.Row="1" BackgroundColor="#FFFFFF">


            <ScrollView>

                <VerticalStackLayout Spacing="15">
                    <Entry Placeholder="Private Name" Text="{Binding EntryPrivateName}" />
                    <Label Style="{StaticResource errorLabel}" Text="{Binding LblErrorPrivateName}" />

                    <Entry Placeholder="Family Name" Text="{Binding EntryFamilyName}" />
                    <Label Style="{StaticResource errorLabel}" Text="{Binding LblErrorFamilyName}" />

                    <Entry Placeholder="Email" Text="{Binding EntryEmail}" />
                    <Label Style="{StaticResource errorLabel}" Text="{Binding LblErrorEmail}" />
                    <Label Text="תכתוב תאריך לידה בבקשה" />
                    <DatePicker
                        Date="{Binding EntryBirthDate}"
                        MaximumDate="{Binding MaximumDate}"
                        Style="{StaticResource errorDatePicker}" />
                    <Label Style="{StaticResource errorLabel}" Text="{Binding ErrorBirthDate}" />

                    --><!--  Start password Grid  --><!--
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            Grid.Column="0"
                            IsPassword="{Binding HidePass}"
                            Placeholder="Your Password"
                            Text="{Binding EntryPassword}" />


                        <Button
                            Grid.Column="1"
                            BackgroundColor="{StaticResource BenPrimary}"
                            Command="{Binding ShowPassCommand}"
                            ImageSource="eye.png"
                            IsEnabled="True"
                            WidthRequest="30" />

                        --><!--  Clicked="OnShowPassButtonClicked"  --><!--
                    </Grid>
                    <Label Style="{StaticResource errorLabel}" Text="{Binding ErrorPassword}" />
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry
                            IsPassword="{Binding HideReTypePass}"
                            Placeholder="RetypePassword"
                            Text="{Binding ReTypePass}" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="{StaticResource BenPrimary}"
                            Command="{Binding ShowReTypePassCommand}"
                            ImageSource="eye.png"
                            IsEnabled="True"
                            WidthRequest="30" />
                    </Grid>
                    <Label Style="{StaticResource errorLabel}" Text="{Binding ErrorReTypePass}" />

                    --><!--  End password Grid  --><!--
                </VerticalStackLayout>

            </ScrollView>
        </Frame>


        --><!--  FOOTER  --><!--
        <Grid
            Grid.Row="3"
            ColumnDefinitions="*,*"
            ColumnSpacing="5"
            RowDefinitions="*,*">
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource BenPrimary}"
                Command="{Binding TryRegisterCommand}"
                CornerRadius="20"
                HorizontalOptions="Fill"
                IsEnabled="True"
                Text="הרשמה"
                TextColor="White"
                VerticalOptions="Center" />

            <Button
                Grid.Row="1"
                Grid.Column="0"
                Background="Transparent"
                Command="{Binding ResetCommand}"
                HorizontalOptions="Fill"
                Text="איפוס שדות"
                TextColor="{StaticResource BenPrimary}" />



            <Button
                Grid.Row="1"
                Grid.Column="1"
                Background="Transparent"
                Command="{Binding GoToLoginCommand}"
                HorizontalOptions="Fill"
                IsEnabled="True"
                Text="יש לך חשבון?"
                TextColor="{StaticResource BenPrimary}" />




        </Grid>
    </Grid>-->
</ContentPage>