<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="benProj.Views.CreatingPath"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="בניית מסלול">


    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#1A237E" Offset="0.0" />
                <GradientStop Color="White" Offset="0.4" />
            </LinearGradientBrush>
        </Grid.Background>

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,10,0,30">
            <Label Text="בניית מסלול חדש" 
               FontSize="28" 
               FontAttributes="Bold" 
               TextColor="White" 
               HorizontalTextAlignment="Center" />
            <Label Text="הקלטת נתוני ריצה בזמן אמת" 
               FontSize="14" 
               TextColor="White" 
               Opacity="0.8" 
               HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="1" 
           CornerRadius="20" 
           HasShadow="True" 
           Padding="0" 
           BorderColor="#E0E0E0"
           BackgroundColor="#F8F9FA">
            <Grid RowDefinitions="*, Auto">
                <VerticalStackLayout VerticalOptions="Center" Spacing="10">
                    <Label Text="📍" FontSize="50" HorizontalOptions="Center" />
                    <Label Text="ממתין לתחילת פעילות..." 
                       TextColor="Gray" 
                       HorizontalOptions="Center" />
                </VerticalStackLayout>

                <BoxView Grid.Row="1" HeightRequest="5" Color="{StaticResource BenPrimary}" />
            </Grid>
        </Frame>

        <Grid Grid.Row="2" ColumnDefinitions="*, *" ColumnSpacing="20" Margin="0,30,0,20">

            <Button Grid.Column="0"
                Text="START"
                Command="{Binding StartCommand}"
                BackgroundColor="#2ECC71"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="20"
                HeightRequest="100"
                WidthRequest="100"
                CornerRadius="50"
                />

            <Button Grid.Column="1"
                Text="STOP"
                Command="{Binding StopCommand}"
                BackgroundColor="#E74C3C"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="20"
                HeightRequest="100"
                WidthRequest="100"
                CornerRadius="50"
                Opacity="0.9"
                />

        </Grid>
    </Grid>
