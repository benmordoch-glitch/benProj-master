<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="benProj.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="LoginPage">
    <Grid
        Padding="20,0,20,0"
        ColumnSpacing="10"
        RowDefinitions="auto,*,auto"
        RowSpacing="10">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="{StaticResource BenPrimary}" />
                <GradientStop Offset="0.5" Color="White" />
            </LinearGradientBrush>
        </Grid.Background>
        <Label
            Margin="4"
            BackgroundColor="Transparent"
            FontSize="13"
            HorizontalOptions="Center"
            Text="ברוכים הבאים "
            TextColor="White"
            VerticalOptions="Center" />


        <Frame Grid.Row="1" BackgroundColor="White">
            <ScrollView>
                <VerticalStackLayout Spacing="15">
                    <Entry Placeholder="Enter Email" Text="{Binding EmailEntry}" />
                    <Label Style="{StaticResource errorLabel}" Text="{Binding LblErrorEmail}" />
                    <Grid ColumnDefinitions="*,auto">
                        <Entry
                            Grid.Column="0"
                            IsPassword="{Binding ShowPassword}"
                            Placeholder="Enter Password"
                            Text="{Binding PasswordEntry}" />

                        <Button
                            Grid.Column="1"
                            BackgroundColor="{StaticResource BenPrimary}"
                            Command="{Binding ViewPassCommand}"
                            HeightRequest="35"
                            ImageSource="eye.png"
                            IsEnabled="True"
                            WidthRequest="40" />
                    </Grid> 

                    <Label
                     Style="{StaticResource errorLabel}"
                     Text="{Binding PasswordError}"
                     TextColor="Red" 
                     FontSize="30"/>
                </VerticalStackLayout>

            </ScrollView>
        </Frame> 
        <Grid
            Grid.Row="3"
            ColumnDefinitions="*,*"
            ColumnSpacing="5"
            RowDefinitions="*,*">
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Background="{StaticResource BenPrimary}"
                Command="{Binding EnterAppCommand}"
                CornerRadius="20"
                HorizontalOptions="Fill"
                Text="היכנס"
                TextColor="White"
                VerticalOptions="Center" />

            <Button
                Grid.Row="1"
                Grid.Column="0"
                Background="Transparent"
                Command="{Binding ResetCommand}"
                HorizontalOptions="Fill"
                Text="איפוס שדות"
                TextColor="{StaticResource BenPrimary}" />

            <Button
                Grid.Row="1"
                Grid.Column="1"
                Background="Transparent"
                Command="{Binding GoToRegisterCommand}"
                HorizontalOptions="Fill"
                IsEnabled="True"
                Text="אין לך חשבון?"
                TextColor="{StaticResource BenPrimary}" />
        </Grid>
    </Grid>


