<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="benProj.Views.CoursePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:benProj.Models"
    xmlns:viewmodels="clr-namespace:benProj.ViewModels"
    Title="מסלולים">
    <VerticalStackLayout>
        <Label
            FontSize="25"
            HorizontalOptions="Center"
            Text="מסלולים"
            VerticalOptions="Center" />

        <CollectionView ItemsSource="{Binding Courses}">

            <CollectionView.EmptyView>
                <Label HorizontalTextAlignment="Center" Text="אין מסלולים." />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Course">
                    <Border StrokeThickness="1" Background="SeaGreen">
                        <StackLayout Margin="5" BackgroundColor="White">
                            
                            <Label
                                FontAttributes="Bold"
                                FontSize="15"
                                HorizontalTextAlignment="Center"
                               Text="{Binding CourseName}"
                                TextDecorations="Underline" />
                            <Button
                                     Text="{Binding CourseName}"
                                    BackgroundColor="DarkBlue"
                                    IsEnabled="True"
                                Command="{Binding GoToTrainingOnlyFilteredCommand}"
                                  

                            />
                            <HorizontalStackLayout>
                                <Label
                                    HorizontalTextAlignment="Start"
                                    Text="{Binding Distance}"
                                    TextColor="blue"
                                    FontSize="35"/>
                                <Label
                                    HorizontalTextAlignment="Start"
                                    Text="m"
                                    TextColor="blue" 
                                    FontSize="35"/>

                            </HorizontalStackLayout>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*,*">
                                <Ellipse
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    Fill="{StaticResource BenPrimary}"
                                    HeightRequest="40"
                                    WidthRequest="40" />
                                <Label
                                    Grid.Row="1"
                                    Grid.Column="3"
                                    FontSize="20"
                                    HorizontalOptions="Center"
                                    Text="{Binding Difficulty}"
                                    TextColor="White"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="3"
                                    HorizontalTextAlignment="Center"
                                    Text="רמת קושי"
                                    TextColor="blue" />
                            </Grid>
                        </StackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Background="Transparent"
            Command="{Binding GoToTrainingCommand}"
            FontSize="20"
            HorizontalOptions="Fill"
            IsEnabled="True"
            Text="לאימונים"
            TextColor="{StaticResource BenPrimary}" />

    </VerticalStackLayout>
</ContentPage>